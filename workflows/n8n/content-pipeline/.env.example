# Content Pipeline — Environment Variables
# Kopieer dit naar .env en vul in

# n8n
N8N_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here

# AI Provider: openai | anthropic | both
AI_PROVIDER=both

# Credential namen — exact zoals ze in n8n staan (Settings > Credentials)
OPENAI_CREDENTIAL_NAME=OpenAI
ANTHROPIC_CREDENTIAL_NAME=Anthropic
NOTION_CREDENTIAL_NAME=Notion
SLACK_CREDENTIAL_NAME=Slack

# Notion database ID (uit de URL van je database page)
NOTION_DATABASE_ID=your_notion_database_id_here

# Slack channel
SLACK_CHANNEL=#content-pipeline
